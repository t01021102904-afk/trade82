model UserProfile {
  id                              String                           @id @default(cuid())
  clerkUserId                     String                           @unique
  email                           String                           @unique
  displayName                     String
  avatarOriginalUrl               String?
  avatarUrl                       String?
  companyAffiliation              String                           @default("")
  jobTitle                        String                           @default("")
  department                      String                           @default("")
  bio                             String                           @default("")
  phoneNumber                     String                           @default("")
  linkedinUrl                     String                           @default("")
  country                         String                           @default("")
  city                            String                           @default("")
  role                            AccountRole
  preferredLanguage               PreferredLanguage                @default(en)
  deletionStatus                  AccountDeletionStatus            @default(ACTIVE)
  deletionRequestedAt             DateTime?
  deletedAt                       DateTime?
  companies                       Company[]
  requestedVerifications          VerificationRequest[]            @relation("RequestedVerification")
  reviewedVerifications           VerificationRequest[]            @relation("ReviewedVerification")
  sentInquiries                   Inquiry[]                        @relation("InquirySender")
  sentMessages                    Message[]                        @relation("MessageSender")
  receivedMessages                Message[]                        @relation("MessageReceiver")
  uploadedMessageAttachments      MessageAttachment[]              @relation("MessageAttachmentUploader")
  createdDocumentFolders          DocumentFolder[]                 @relation("CreatedDocumentFolders")
  uploadedTradeDocuments          TradeDocument[]                  @relation("UploadedTradeDocuments")
  savedItems                      SavedItem[]
  createdDeals                    Deal[]                           @relation("DealCreator")
  buyerRfqRequests                RfqRequest[]                     @relation("BuyerRfqRequests")
  reviewedRfqRequests             RfqRequest[]                     @relation("ReviewedRfqRequests")
  marketingExposures              MarketingExposure[]
  createdPaymentRequests          PaymentRequest[]                 @relation("PaymentRequestCreator")
  releasedPaymentRequests         PaymentRequest[]                 @relation("PaymentRequestReleasedBy")
  paymentRequestEvents            PaymentRequestEvent[]            @relation("PaymentRequestEventActor")
  tradeOrderEvents                TradeOrderEvent[]                @relation("TradeOrderEventActor")
  sellerPayoutEvents              SellerPayoutEvent[]              @relation("SellerPayoutEventActor")
  sellerPayoutAdjustments         SellerPayoutAdjustment[]         @relation("SellerPayoutAdjustmentActor")
  preparedSellerPayouts           SellerPayout[]                   @relation("SellerPayoutPreparedBy")
  approvedSellerPayouts           SellerPayout[]                   @relation("SellerPayoutApprovedBy")
  sentSellerPayouts               SellerPayout[]                   @relation("SellerPayoutSentBy")
  verifiedSellerPayoutProfiles    SellerPayoutProfile[]            @relation("SellerPayoutProfileVerifiedBy")
  sellerPayoutProfileAuditEvents  SellerPayoutProfileAuditEvent[]  @relation("SellerPayoutProfileAuditActor")
  verifiedPartnerPayoutProfiles   PartnerPayoutProfile[]           @relation("PartnerPayoutProfileVerifiedBy")
  partnerPayoutProfileAuditEvents PartnerPayoutProfileAuditEvent[] @relation("PartnerPayoutProfileAuditActor")
  preparedPartnerPayouts          PartnerPayout[]                  @relation("PartnerPayoutPreparedBy")
  sentPartnerPayouts              PartnerPayout[]                  @relation("PartnerPayoutSentBy")
  partnerPayoutEvents             PartnerPayoutEvent[]             @relation("PartnerPayoutEventActor")
  partnerProfileAuditEvents       PartnerProfileAuditEvent[]       @relation("PartnerProfileAuditActor")
  settlementEvents                SettlementEvent[]                @relation("SettlementEventActor")
  approvedSettlements             Settlement[]                     @relation("SettlementApprovedBy")
  partnerProfile                  PartnerProfile?                  @relation("UserPartnerProfile")
  referredReferralAttribution     ReferralAttribution?             @relation("ReferredUserAttribution")
  consumedReferralClaimTokens     ReferralClaimToken[]             @relation("ReferralClaimConsumedByUser")
  settlementLegRecipientUsers     SettlementLeg[]                  @relation("SettlementLegRecipientUser")
  acknowledgedSettlementAlerts    SettlementOperationalAlert[]     @relation("SettlementOperationalAlertAcknowledgedBy")
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt

  @@index([deletionStatus, deletedAt])
}

model Company {
  id                                String                       @id @default(cuid())
  ownerUserId                       String
  owner                             UserProfile                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  companyRole                       CompanyRole
  legalName                         String
  tradeName                         String?
  displayNameEn                     String                       @default("")
  logoOriginalUrl                   String?
  logoThumbnailUrl                  String?
  logoUrl                           String?
  useDefaultLogo                    Boolean                      @default(true)
  website                           String                       @default("")
  country                           String
  city                              String                       @default("")
  stateOrProvince                   String                       @default("")
  businessAddress                   String
  description                       String                       @default("")
  descriptionEn                     String                       @default("")
  categories                        String[]                     @default([])
  viewCount                         Int                          @default(0)
  verificationStatus                CompanyVerificationStatus    @default(unverified)
  deletedAt                         DateTime?
  stripeCustomerId                  String?                      @unique
  stripeSubscriptionId              String?                      @unique
  subscriptionStatus                String?
  subscriptionPlan                  String?
  subscriptionCurrentPeriodEnd      DateTime?
  verifiedSellerSince               DateTime?
  sellerSupportPlan                 String?
  sellerSupportStatus               String?
  sellerSupportStripeCustomerId     String?                      @unique
  sellerSupportStripeSubscriptionId String?                      @unique
  sellerSupportCurrentPeriodEnd     DateTime?
  sellerSupportMonthlyLimit         Int                          @default(0)
  sellerSupportMonthlyUsed          Int                          @default(0)
  sellerProfile                     SellerProfile?
  buyerProfile                      BuyerProfile?
  products                          Product[]
  verificationRequests              VerificationRequest[]
  buyerInquiries                    Inquiry[]                    @relation("BuyerCompanyInquiries")
  sellerInquiries                   Inquiry[]                    @relation("SellerCompanyInquiries")
  recipientInquiries                Inquiry[]                    @relation("RecipientCompanyInquiries")
  rfqSellerQuotes                   RfqSellerQuote[]             @relation("SellerCompanyRfqQuotes")
  sentCompanyMessages               Message[]                    @relation("MessageSenderCompany")
  receivedMessages                  Message[]                    @relation("MessageReceiverCompany")
  uploadedMessageAttachments        MessageAttachment[]          @relation("MessageAttachmentCompany")
  documentFolders                   DocumentFolder[]             @relation("CompanyDocumentFolders")
  tradeDocuments                    TradeDocument[]              @relation("CompanyTradeDocuments")
  sharedTradeDocuments              TradeDocument[]              @relation("SharedBuyerDocuments")
  savedItems                        SavedItem[]
  buyerDeals                        Deal[]                       @relation("BuyerCompanyDeals")
  sellerDeals                       Deal[]                       @relation("SellerCompanyDeals")
  buyerRfqRequests                  RfqRequest[]                 @relation("BuyerCompanyRfqs")
  marketingExposures                MarketingExposure[]
  buyerPaymentRequests              PaymentRequest[]             @relation("BuyerCompanyPaymentRequests")
  sellerPaymentRequests             PaymentRequest[]             @relation("SellerCompanyPaymentRequests")
  buyerTradeOrders                  TradeOrder[]                 @relation("BuyerCompanyTradeOrders")
  sellerTradeOrders                 TradeOrder[]                 @relation("SellerCompanyTradeOrders")
  sellerPayoutProfile               SellerPayoutProfile?         @relation("SellerCompanyPayoutProfile")
  sellerPayouts                     SellerPayout[]               @relation("SellerCompanyPayouts")
  stripeConnectedAccount            StripeConnectedAccount?      @relation("CompanyStripeConnectedAccount")
  sellerStripeMerchantAccount       SellerStripeMerchantAccount? @relation("CompanySellerStripeMerchantAccount")
  settlementLegRecipients           SettlementLeg[]              @relation("SettlementLegRecipientCompany")
  reviewsWritten                    Review[]                     @relation("ReviewWriter")
  reviewsReceived                   Review[]                     @relation("ReviewRecipient")
  companyReviewsWritten             CompanyReview[]              @relation("CompanyReviewWriter")
  companyReviewsReceived            CompanyReview[]              @relation("CompanyReviewRecipient")
  createdAt                         DateTime                     @default(now())
  updatedAt                         DateTime                     @updatedAt

  @@unique([ownerUserId, companyRole])
  @@index([companyRole, verificationStatus])
  @@index([deletedAt, companyRole, verificationStatus])
  @@index([subscriptionStatus, subscriptionPlan])
  @@index([sellerSupportStatus, sellerSupportPlan])
}

model SellerProfile {
  id                               String   @id @default(cuid())
  companyId                        String   @unique
  company                          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  koreanBusinessRegistrationNumber String
  representativeName               String
  exportExperience                 String
  exportExperienceEn               String   @default("")
  exportCountries                  String[] @default([])
  productCategories                String[] @default([])
  minimumOrderQuantity             String
  leadTime                         String
  certifications                   String[] @default([])
  shippingTerms                    String[] @default([])
  paymentTerms                     String[] @default([])
  factoryOrDistributorStatus       String
}

model BuyerProfile {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buyerType             String
  purchasingCategories  String[] @default([])
  preferredSupplierType String   @default("")
  targetOrderSize       String
  monthlyImportVolume   String
  importExperience      String
  purchaseTimeline      String
  salesChannels         String[] @default([])
}

model Product {
  id                       String              @id @default(cuid())
  sellerCompanyId          String
  sellerCompany            Company             @relation(fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  name                     String
  nameEn                   String              @default("")
  slug                     String              @unique
  imageUrl                 String?
  category                 String
  tags                     String[]            @default([])
  tagsEn                   String[]            @default([])
  shortDescription         String
  shortDescriptionEn       String              @default("")
  detailedDescription      String
  detailedDescriptionEn    String              @default("")
  priceMin                 Decimal?            @db.Decimal(14, 2)
  priceMax                 Decimal?            @db.Decimal(14, 2)
  currency                 String              @default("USD")
  priceUnit                String              @default("unit")
  moq                      String
  moqQuantity              String              @default("")
  moqUnit                  String              @default("Units")
  leadTime                 String
  leadTimeCode             String              @default("")
  sampleAvailability       String              @default("")
  privateLabelAvailability String              @default("")
  monthlyCapacity          String              @default("")
  monthlyCapacityUnit      String              @default("Units")
  origin                   String              @default("South Korea")
  countryOfOrigin          String              @default("South Korea")
  shippingOriginCountry    String              @default("South Korea")
  shippingOriginRegion     String              @default("")
  incoterms                String[]            @default([])
  hsCode                   String              @default("")
  shelfLife                String              @default("")
  storageRequirements      String              @default("")
  documentsAvailable       String[]            @default([])
  complianceClaims         String[]            @default([])
  buyerNotes               String              @default("")
  buyerNotesEn             String              @default("")
  riskNotes                String[]            @default([])
  certifications           String[]            @default([])
  ingredientsOrMaterials   String
  packaging                String
  packageSize              String              @default("")
  unitsPerCarton           String              @default("")
  cartonWeight             String              @default("")
  cartonDimensions         String              @default("")
  palletQuantity           String              @default("")
  storageTemperature       String              @default("")
  suggestedUsChannels      String[]            @default([])
  fieldVisibility          Json                @default("{}") @map("field_visibility")
  exportReadiness          Boolean             @default(false)
  viewCount                Int                 @default(0)
  status                   ProductStatus       @default(draft)
  deletedAt                DateTime?
  images                   ProductImage[]
  inquiries                Inquiry[]
  savedItems               SavedItem[]
  deals                    Deal[]
  rfqMatches               RfqMatchedProduct[]
  rfqSellerQuotes          RfqSellerQuote[]
  marketingExposures       MarketingExposure[]
  orderItems               TradeOrderItem[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([sellerCompanyId, status])
  @@index([deletedAt, sellerCompanyId, status])
  @@index([category])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalUrl String
  cardUrl     String
  mainUrl     String
  detailUrl   String
  storagePath String
  position    Int
  width       Int?
  height      Int?
  altText     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, position])
  @@index([productId, position])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationRequest {
  id                String                    @id @default(cuid())
  companyId         String
  company           Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedByUserId String
  requestedBy       UserProfile               @relation("RequestedVerification", fields: [requestedByUserId], references: [id])
  status            VerificationRequestStatus @default(pending_review)
  documentUrl       String?
  documentPath      String?
  documentFilename  String?
  adminNote         String?
  reviewedByUserId  String?
  reviewedBy        UserProfile?              @relation("ReviewedVerification", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([status, createdAt])
}

model Inquiry {
  id                 String              @id @default(cuid())
  buyerCompanyId     String
  buyerCompany       Company             @relation("BuyerCompanyInquiries", fields: [buyerCompanyId], references: [id])
  sellerCompanyId    String
  sellerCompany      Company             @relation("SellerCompanyInquiries", fields: [sellerCompanyId], references: [id])
  productId          String?
  product            Product?            @relation(fields: [productId], references: [id])
  senderUserId       String
  sender             UserProfile         @relation("InquirySender", fields: [senderUserId], references: [id])
  recipientCompanyId String
  recipientCompany   Company             @relation("RecipientCompanyInquiries", fields: [recipientCompanyId], references: [id])
  message            String
  quantity           String?
  targetDate         DateTime?
  status             InquiryStatus       @default(sent)
  messages           Message[]
  attachments        MessageAttachment[]
  deals              Deal[]
  paymentRequests    PaymentRequest[]
  tradeOrders        TradeOrder[]
  rfqSellerQuotes    RfqSellerQuote[]    @relation("RfqQuoteConversation")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([buyerCompanyId, sellerCompanyId])
  @@index([recipientCompanyId, status])
}

model RfqRequest {
  id                         String              @id @default(cuid())
  buyerUserId                String
  buyerUser                  UserProfile         @relation("BuyerRfqRequests", fields: [buyerUserId], references: [id], onDelete: Cascade)
  buyerCompanyId             String?
  buyerCompany               Company?            @relation("BuyerCompanyRfqs", fields: [buyerCompanyId], references: [id], onDelete: SetNull)
  productName                String
  category                   String
  sourcingType               String
  sourcingPurpose            String?
  quantity                   String
  tradeTerms                 String
  destinationCountry         String?
  preferredUnitPriceAmount   Decimal?            @db.Decimal(14, 2)
  preferredUnitPriceCurrency String?
  shape                      String?
  capacity                   String?
  material                   String?
  certification              String?
  feature                    String?
  targetDeliveryDate         DateTime?
  details                    String
  status                     RfqStatus           @default(SUBMITTED)
  adminStatus                RfqAdminStatus      @default(PENDING_REVIEW)
  adminNote                  String?
  reviewedByUserId           String?
  reviewedByUser             UserProfile?        @relation("ReviewedRfqRequests", fields: [reviewedByUserId], references: [id])
  reviewedAt                 DateTime?
  matchedProducts            RfqMatchedProduct[]
  sellerQuotes               RfqSellerQuote[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  @@index([buyerUserId, createdAt])
  @@index([buyerCompanyId, createdAt])
  @@index([status, createdAt])
  @@index([adminStatus, createdAt])
}

model RfqMatchedProduct {
  id           String     @id @default(cuid())
  rfqRequestId String
  rfqRequest   RfqRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  rank         Int
  reasons      String[]   @default([])
  createdAt    DateTime   @default(now())

  @@unique([rfqRequestId, productId])
  @@index([rfqRequestId, rank])
  @@index([productId])
}

model RfqSellerQuote {
  id                    String               @id @default(cuid())
  rfqRequestId          String
  rfqRequest            RfqRequest           @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  sellerCompanyId       String
  sellerCompany         Company              @relation("SellerCompanyRfqQuotes", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  productId             String?
  product               Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  conversationId        String?
  conversation          Inquiry?             @relation("RfqQuoteConversation", fields: [conversationId], references: [id], onDelete: SetNull)
  status                RfqSellerQuoteStatus @default(REQUESTED)
  unitPriceAmount       Decimal?             @db.Decimal(14, 2)
  unitPriceCurrency     String?
  moq                   String?
  leadTime              String?
  incoterms             String?
  sampleAvailable       Boolean?
  privateLabelAvailable Boolean?
  notes                 String?
  submittedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([rfqRequestId, sellerCompanyId])
  @@index([rfqRequestId, status])
  @@index([sellerCompanyId, createdAt])
  @@index([productId])
  @@index([conversationId])
}

model MarketingExposure {
  id                      String                  @id @default(cuid())
  companyId               String
  company                 Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId               String
  product                 Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId                  String
  user                    UserProfile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                    MarketingExposurePlan
  status                  MarketingExposureStatus @default(PENDING)
  stripeCustomerId        String?
  stripeCheckoutSessionId String?                 @unique
  stripePaymentIntentId   String?
  priceId                 String
  amount                  Int
  currency                String                  @default("usd")
  startsAt                DateTime?
  endsAt                  DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([companyId, status])
  @@index([productId, status])
  @@index([status, startsAt, endsAt])
}

model PaymentRequest {
  id                           String                       @id @default(cuid())
  inquiryId                    String
  inquiry                      Inquiry                      @relation(fields: [inquiryId], references: [id], onDelete: Restrict)
  buyerCompanyId               String
  buyerCompany                 Company                      @relation("BuyerCompanyPaymentRequests", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompanyId              String
  sellerCompany                Company                      @relation("SellerCompanyPaymentRequests", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  createdByUserId              String
  createdByUser                UserProfile                  @relation("PaymentRequestCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  productName                  String
  quantity                     String
  unit                         String
  productAmount                Int
  shippingAmount               Int
  grossAmount                  Int
  platformFeeAmount            Int
  sellerPayableAmount          Int
  stripeProcessingFeeAmount    Int?
  stripeFeeSyncStatus          StripeFeeSyncStatus          @default(PENDING)
  stripeFeeSyncError           String?
  stripeFeeSyncedAt            DateTime?
  refundAmount                 Int                          @default(0)
  currency                     String                       @default("usd")
  paymentDueDate               DateTime
  orderTerms                   String
  status                       PaymentRequestStatus         @default(PENDING)
  stripeCheckoutSessionId      String?                      @unique
  stripePaymentIntentId        String?                      @unique
  stripeChargeId               String?                      @unique
  checkoutAttempt              Int                          @default(0)
  checkoutLockToken            String?
  checkoutLockExpiresAt        DateTime?
  paidAt                       DateTime?
  cancelledAt                  DateTime?
  releasedAt                   DateTime?
  manualPayoutReference        String?
  manualPayoutDate             DateTime?
  manualPayoutNote             String?
  sellerReleasedAmount         Int?
  releasedByUserId             String?
  releasedByUser               UserProfile?                 @relation("PaymentRequestReleasedBy", fields: [releasedByUserId], references: [id], onDelete: SetNull)
  requiresManualReconciliation Boolean                      @default(false)
  reconciliationNote           String?
  orderId                      String?                      @unique
  order                        TradeOrder?                  @relation("PaymentRequestOrder", fields: [orderId], references: [id], onDelete: Restrict)
  tradeOrderByPaymentRequest   TradeOrder?                  @relation("TradeOrderPaymentRequest")
  refunds                      PaymentRefund[]
  disputes                     PaymentDispute[]
  events                       PaymentRequestEvent[]
  webhookEvents                PaymentRequestWebhookEvent[]
  connectSettlement            Settlement?                  @relation("PaymentRequestConnectSettlement")
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  @@index([inquiryId, createdAt])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
  @@index([status, paymentDueDate])
  @@index([status, checkoutLockExpiresAt])
}

model PaymentRefund {
  id                       String         @id @default(cuid())
  paymentRequestId         String
  paymentRequest           PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeRefundId           String         @unique
  amount                   Int
  status                   String
  lastStripeEventCreatedAt DateTime
  lastStripeEventId        String
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([paymentRequestId, createdAt])
}

model PaymentDispute {
  id                       String         @id @default(cuid())
  paymentRequestId         String
  paymentRequest           PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeDisputeId          String         @unique
  amount                   Int
  status                   String
  reason                   String?
  lastStripeEventCreatedAt DateTime
  lastStripeEventId        String
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([paymentRequestId, createdAt])
}

model PaymentRequestEvent {
  id               String                  @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest          @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  eventType        PaymentRequestEventType
  actorUserId      String?
  actorUser        UserProfile?            @relation("PaymentRequestEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  stripeEventId    String?                 @unique
  message          String?
  metadata         Json                    @default("{}")
  createdAt        DateTime                @default(now())

  @@index([paymentRequestId, createdAt])
  @@index([eventType, createdAt])
}

model PaymentRequestWebhookEvent {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeEventId    String         @unique
  stripeEventType  String
  createdAt        DateTime       @default(now())

  @@index([paymentRequestId, createdAt])
}

// Settlement records are deliberately separate from the existing manual payout
// system. They reserve future Stripe Connect accounting without changing the
// current PaymentRequest, TradeOrder, or SellerPayout lifecycle.
model PartnerProfile {
  id                         String                      @id @default(cuid())
  userId                     String                      @unique
  user                       UserProfile                 @relation("UserPartnerProfile", fields: [userId], references: [id], onDelete: Restrict)
  referralCode               String                      @unique
  status                     PartnerProfileStatus        @default(ACTIVE)
  legalName                  String?
  displayName                String?
  contactEmail               String?
  contactPhone               String?
  country                    String?
  preferredLanguage          PreferredLanguage?
  organizationName           String?
  websiteOrSocialUrl         String?
  promotionDescription       String?
  termsConsentVersion        String?
  termsConsentedAt           DateTime?
  payoutTermsConsentVersion  String?
  payoutTermsConsentedAt     DateTime?
  privacyConsentVersion      String?
  privacyConsentedAt         DateTime?
  deletedAt                  DateTime?
  attributions               ReferralAttribution[]
  referralClickDailyVisitors ReferralClickDailyVisitor[]
  referralConversions        ReferralConversion[]
  referralClaimTokens        ReferralClaimToken[]
  stripeConnectedAccount     StripeConnectedAccount?     @relation("PartnerProfileStripeConnectedAccount")
  payoutProfile              PartnerPayoutProfile?
  partnerPayouts             PartnerPayout[]
  auditEvents                PartnerProfileAuditEvent[]
  settlementLegs             SettlementLeg[]             @relation("SettlementLegPartnerProfile")
  settlements                Settlement[]                @relation("SettlementReferralPartnerProfile")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@index([status, createdAt])
  @@index([deletedAt, status])
}

// Opaque, short-lived referral evidence. The browser only ever receives the
// raw token; the database stores its SHA-256 hash.
model ReferralClaimToken {
  id               String         @id @default(cuid())
  tokenHash        String         @unique
  partnerProfileId String
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedByUserId String?
  consumedByUser   UserProfile?   @relation("ReferralClaimConsumedByUser", fields: [consumedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime       @default(now())

  @@index([partnerProfileId, expiresAt])
  @@index([consumedByUserId, createdAt])
}

// The first valid attribution for a referred user is immutable. Later
// referrals are ignored by the service layer rather than replacing history.
model ReferralAttribution {
  id               String                    @id @default(cuid())
  referredUserId   String                    @unique
  referredUser     UserProfile               @relation("ReferredUserAttribution", fields: [referredUserId], references: [id], onDelete: Restrict)
  partnerProfileId String
  partnerProfile   PartnerProfile            @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  referralCode     String
  status           ReferralAttributionStatus @default(LOCKED)
  lockedAt         DateTime                  @default(now())
  settlements      Settlement[]
  conversions      ReferralConversion[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([partnerProfileId, lockedAt])
}

model ReferralClickDailyVisitor {
  id               String         @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  visitorHash      String
  day              DateTime       @db.Date
  clickCount       Int            @default(1)
  firstClickedAt   DateTime       @default(now())
  lastClickedAt    DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([partnerProfileId, visitorHash, day])
  @@index([partnerProfileId, day])
}

model ReferralConversion {
  id                    String              @id @default(cuid())
  partnerProfileId      String
  partnerProfile        PartnerProfile      @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  referralAttributionId String
  referralAttribution   ReferralAttribution @relation(fields: [referralAttributionId], references: [id], onDelete: Restrict)
  subjectType           ReferralSubjectType
  convertedAt           DateTime
  createdAt             DateTime            @default(now())

  @@unique([referralAttributionId, subjectType])
  @@index([partnerProfileId, convertedAt])
}

model StripeConnectedAccount {
  id                 String                       @id @default(cuid())
  companyId          String?                      @unique
  company            Company?                     @relation("CompanyStripeConnectedAccount", fields: [companyId], references: [id], onDelete: Restrict)
  partnerProfileId   String?                      @unique
  partnerProfile     PartnerProfile?              @relation("PartnerProfileStripeConnectedAccount", fields: [partnerProfileId], references: [id], onDelete: Restrict)
  stripeAccountId    String                       @unique
  status             StripeConnectedAccountStatus @default(PENDING)
  chargesEnabled     Boolean                      @default(false)
  payoutsEnabled     Boolean                      @default(false)
  transfersEnabled   Boolean                      @default(false)
  detailsSubmitted   Boolean                      @default(false)
  onboardingComplete Boolean                      @default(false)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([status, updatedAt])
}

// This is separate from StripeConnectedAccount: it is the seller's future
// Direct Charges merchant account, not a settlement-transfer recipient.
model SellerStripeMerchantAccount {
  id                       String                            @id @default(cuid())
  companyId                String                            @unique
  company                  Company                           @relation("CompanySellerStripeMerchantAccount", fields: [companyId], references: [id], onDelete: Restrict)
  stripeAccountId          String                            @unique
  country                  String
  status                   SellerStripeMerchantAccountStatus @default(ONBOARDING_INCOMPLETE)
  chargesEnabled           Boolean                           @default(false)
  payoutsEnabled           Boolean                           @default(false)
  cardPaymentsEnabled      Boolean                           @default(false)
  transfersEnabled         Boolean                           @default(false)
  detailsSubmitted         Boolean                           @default(false)
  onboardingComplete       Boolean                           @default(false)
  requirementsOutstanding  Boolean                           @default(false)
  controllerFeesPayer      String                            @default("account")
  controllerLossesPayments String                            @default("stripe")
  dashboardType            String                            @default("full")
  createdAt                DateTime                          @default(now())
  updatedAt                DateTime                          @updatedAt

  @@index([status, updatedAt])
}

model Settlement {
  id                                    String                       @id @default(cuid())
  paymentRequestId                      String                       @unique
  paymentRequest                        PaymentRequest               @relation("PaymentRequestConnectSettlement", fields: [paymentRequestId], references: [id], onDelete: Restrict)
  tradeOrderId                          String                       @unique
  tradeOrder                            TradeOrder                   @relation("TradeOrderConnectSettlement", fields: [tradeOrderId], references: [id], onDelete: Restrict)
  referralAttributionId                 String?
  referralAttribution                   ReferralAttribution?         @relation(fields: [referralAttributionId], references: [id], onDelete: Restrict)
  referralPartnerProfileId              String?
  referralPartnerProfile                PartnerProfile?              @relation("SettlementReferralPartnerProfile", fields: [referralPartnerProfileId], references: [id], onDelete: Restrict)
  referralCodeSnapshot                  String?
  referralSubjectType                   ReferralSubjectType?
  referredUserIdSnapshot                String?
  grossAmount                           Int
  platformFeeAmount                     Int
  sellerPayableAmount                   Int
  partnerReferralAmount                 Int                          @default(0)
  trade82RetainedAmountBeforeStripeFees Int
  currency                              String                       @default("usd")
  paymentFlow                           SettlementPaymentFlow        @default(SCT)
  holdUntil                             DateTime
  status                                SettlementStatus             @default(HOLD)
  approvedAt                            DateTime?
  approvedByUserId                      String?
  approvedByUser                        UserProfile?                 @relation("SettlementApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  holdReason                            String?                      @db.VarChar(1000)
  idempotencyKey                        String                       @unique
  legs                                  SettlementLeg[]
  events                                SettlementEvent[]
  reversals                             SettlementReversal[]
  operationalAlerts                     SettlementOperationalAlert[]
  partnerPayout                         PartnerPayout?
  createdAt                             DateTime                     @default(now())
  updatedAt                             DateTime                     @updatedAt

  @@index([status, holdUntil])
  @@index([approvedByUserId])
  @@index([referralAttributionId])
  @@index([referralPartnerProfileId])
}

model SettlementLeg {
  id                    String                       @id @default(cuid())
  settlementId          String
  settlement            Settlement                   @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  type                  SettlementLegType
  recipientCompanyId    String?
  recipientCompany      Company?                     @relation("SettlementLegRecipientCompany", fields: [recipientCompanyId], references: [id], onDelete: Restrict)
  recipientUserId       String?
  recipientUser         UserProfile?                 @relation("SettlementLegRecipientUser", fields: [recipientUserId], references: [id], onDelete: Restrict)
  partnerProfileId      String?
  partnerProfile        PartnerProfile?              @relation("SettlementLegPartnerProfile", fields: [partnerProfileId], references: [id], onDelete: Restrict)
  amount                Int
  currency              String                       @default("usd")
  holdUntil             DateTime
  status                SettlementLegStatus          @default(HOLD)
  idempotencyKey        String                       @unique
  stripeTransferId      String?                      @unique
  transferAttemptCount  Int                          @default(0)
  nextTransferAttemptAt DateTime?
  transferLastError     String?                      @db.VarChar(1000)
  transferLockedAt      DateTime?
  manualReviewRequired  Boolean                      @default(false)
  transferredAt         DateTime?
  events                SettlementEvent[]
  reversals             SettlementReversal[]         @relation("SettlementReversalSettlementLeg")
  operationalAlerts     SettlementOperationalAlert[]
  partnerPayout         PartnerPayout?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@unique([settlementId, type])
  @@unique([settlementId, id])
  @@index([recipientCompanyId, status, holdUntil])
  @@index([recipientUserId, status, holdUntil])
  @@index([partnerProfileId, status, holdUntil])
  @@index([status, holdUntil])
  @@index([status, nextTransferAttemptAt])
}

model SettlementEvent {
  id              String              @id @default(cuid())
  settlementId    String
  settlement      Settlement          @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  settlementLegId String?
  settlementLeg   SettlementLeg?      @relation(fields: [settlementLegId], references: [id], onDelete: Restrict)
  eventType       SettlementEventType
  actorUserId     String?
  actorUser       UserProfile?        @relation("SettlementEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  message         String?
  metadata        Json                @default("{}")
  idempotencyKey  String              @unique
  createdAt       DateTime            @default(now())

  @@index([settlementId, createdAt])
  @@index([settlementLegId, createdAt])
}

model SettlementReversal {
  id                         String                        @id @default(cuid())
  settlementId               String
  settlement                 Settlement                    @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  settlementLegId            String
  settlementLeg              SettlementLeg                 @relation("SettlementReversalSettlementLeg", fields: [settlementId, settlementLegId], references: [settlementId, id], onDelete: Restrict)
  amount                     Int
  requestedAmount            Int?
  successfullyReversedAmount Int                           @default(0)
  currency                   String                        @default("usd")
  reason                     SettlementReversalReason
  sourceType                 SettlementReversalSourceType?
  stripeSourceObjectId       String?
  originalStripeTransferId   String?
  status                     SettlementReversalStatus      @default(ACCOUNTING_APPLIED)
  idempotencyKey             String                        @unique
  stripeRefundId             String?
  stripeDisputeId            String?
  stripeTransferReversalId   String?                       @unique
  reversalAttemptCount       Int                           @default(0)
  manualRequeueCount         Int                           @default(0)
  nextReversalAttemptAt      DateTime?
  reversalLastError          String?                       @db.VarChar(1000)
  reversalLockedAt           DateTime?
  completedAt                DateTime?
  operationalAlerts          SettlementOperationalAlert[]
  createdAt                  DateTime                      @default(now())

  @@unique([stripeRefundId, settlementLegId])
  @@unique([stripeDisputeId, settlementLegId])
  @@index([settlementId, settlementLegId])
  @@index([settlementId, createdAt])
  @@index([settlementLegId, createdAt])
  @@index([status, nextReversalAttemptAt])
  @@index([sourceType, stripeSourceObjectId, settlementLegId])
}

model SettlementWorkerRun {
  id                  String                       @id @default(cuid())
  workerType          SettlementWorkerType
  executionMode       String
  status              SettlementWorkerRunStatus    @default(RUNNING)
  startedAt           DateTime                     @default(now())
  completedAt         DateTime?
  scannedCount        Int                          @default(0)
  claimedCount        Int                          @default(0)
  succeededCount      Int                          @default(0)
  failedCount         Int                          @default(0)
  skippedCount        Int                          @default(0)
  manualReviewCount   Int                          @default(0)
  staleRecoveredCount Int                          @default(0)
  durationMs          Int?
  sanitizedErrorCode  String?                      @db.VarChar(64)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  operationalAlerts   SettlementOperationalAlert[]

  @@index([workerType, status, startedAt])
  @@index([status, startedAt])
}

model SettlementOperationalAlert {
  id                   String                             @id @default(cuid())
  alertType            SettlementOperationalAlertType
  severity             SettlementOperationalAlertSeverity
  status               SettlementOperationalAlertStatus   @default(OPEN)
  settlementId         String?
  settlement           Settlement?                        @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  settlementLegId      String?
  settlementLeg        SettlementLeg?                     @relation(fields: [settlementLegId], references: [id], onDelete: Restrict)
  settlementReversalId String?
  settlementReversal   SettlementReversal?                @relation(fields: [settlementReversalId], references: [id], onDelete: Restrict)
  workerRunId          String?
  workerRun            SettlementWorkerRun?               @relation(fields: [workerRunId], references: [id], onDelete: SetNull)
  title                String
  sanitizedMessage     String                             @db.VarChar(1000)
  occurrenceCount      Int                                @default(1)
  firstOccurredAt      DateTime                           @default(now())
  lastOccurredAt       DateTime                           @default(now())
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  acknowledgedByUser   UserProfile?                       @relation("SettlementOperationalAlertAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  resolvedAt           DateTime?
  deduplicationKey     String                             @unique
  createdAt            DateTime                           @default(now())
  updatedAt            DateTime                           @updatedAt

  @@index([status, severity, lastOccurredAt])
  @@index([settlementId, status])
  @@index([settlementLegId, status])
  @@index([settlementReversalId, status])
  @@index([workerRunId])
}

// Financial order records deliberately use restrictive foreign keys. Historical
// payments and payout instructions must remain auditable even when other app data
// is otherwise eligible for deletion.
model OrderNumberCounter {
  year               Int      @id
  lastOrderSequence  Int      @default(0)
  lastPayoutSequence Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TradeOrder {
  id                      String              @id @default(cuid())
  orderNumber             String              @unique
  inquiryId               String
  inquiry                 Inquiry             @relation(fields: [inquiryId], references: [id], onDelete: Restrict)
  paymentRequestId        String              @unique
  paymentRequest          PaymentRequest      @relation("TradeOrderPaymentRequest", fields: [paymentRequestId], references: [id], onDelete: Restrict)
  paymentRequestByOrderId PaymentRequest?     @relation("PaymentRequestOrder")
  buyerCompanyId          String
  buyerCompany            Company             @relation("BuyerCompanyTradeOrders", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompanyId         String
  sellerCompany           Company             @relation("SellerCompanyTradeOrders", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  orderStatus             TradeOrderStatus    @default(PAYMENT_PENDING)
  paymentStatus           OrderPaymentStatus  @default(PENDING)
  shipmentStatus          OrderShipmentStatus @default(NOT_READY)
  payoutStatus            OrderPayoutStatus   @default(NOT_READY)

  buyerCompanyName  String
  buyerContactName  String?
  buyerEmail        String
  buyerPhone        String?
  buyerCountry      String
  buyerAddress      String?
  sellerCompanyName String
  sellerContactName String?
  sellerEmail       String
  sellerPhone       String?
  sellerCountry     String
  sellerAddress     String?

  productAmount             Int
  shippingAmount            Int
  grossAmount               Int
  platformFeeRateBps        Int       @default(500)
  platformFeeAmount         Int
  sellerPayableAmount       Int
  stripeProcessingFeeAmount Int?
  refundAmount              Int       @default(0)
  currency                  String    @default("usd")
  paidAt                    DateTime?
  refundedAt                DateTime?
  disputedAt                DateTime?

  items             TradeOrderItem[]
  shipment          TradeOrderShipment?
  events            TradeOrderEvent[]
  payout            SellerPayout?
  partnerPayouts    PartnerPayout[]
  connectSettlement Settlement?         @relation("TradeOrderConnectSettlement")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([buyerCompanyId, createdAt])
  @@index([sellerCompanyId, createdAt])
  @@index([orderStatus, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([payoutStatus, createdAt])
}

model TradeOrderItem {
  id              String     @id @default(cuid())
  orderId         String
  order           TradeOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  productId       String?
  product         Product?   @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  sku             String?
  hsCode          String?
  countryOfOrigin String?
  quantity        String
  unit            String
  unitPrice       Int?
  productAmount   Int
  currency        String     @default("usd")
  productSnapshot Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([orderId, createdAt])
  @@index([productId])
}

model TradeOrderShipment {
  id                   String              @id @default(cuid())
  orderId              String              @unique
  order                TradeOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  incoterm             Incoterm            @default(OTHER)
  shippingMethod       ShippingMethod      @default(OTHER)
  originCountry        String
  originCity           String?
  destinationCountry   String
  destinationCity      String?
  destinationAddress   String?
  carrierName          String?
  freightForwarderName String?
  trackingNumber       String?
  billOfLadingNumber   String?
  airWaybillNumber     String?
  shipmentReference    String?
  shipDate             DateTime?
  estimatedArrivalDate DateTime?
  deliveredAt          DateTime?
  shipmentStatus       OrderShipmentStatus @default(NOT_READY)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([shipmentStatus, updatedAt])
  @@index([destinationCountry])
}

model TradeOrderEvent {
  id          String              @id @default(cuid())
  orderId     String
  order       TradeOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  actorUserId String?
  actorUser   UserProfile?        @relation("TradeOrderEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   TradeOrderEventType
  message     String?
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now())

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model BankDirectory {
  id                    String                  @id @default(cuid())
  countryCode           String
  bankNameLocal         String
  bankNameEnglish       String
  bankCode              String?
  defaultSwiftBic       String?
  defaultBankAddress    String?
  officialWebsite       String?
  sourceUrl             String?
  verifiedAt            DateTime?
  sourceType            BankDirectorySourceType @default(ADMIN)
  isActive              Boolean                 @default(true)
  payoutProfiles        SellerPayoutProfile[]
  partnerPayoutProfiles PartnerPayoutProfile[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([countryCode, bankNameEnglish])
  @@index([countryCode, isActive])
}

model SellerPayoutProfile {
  id                      String                          @id @default(cuid())
  companyId               String                          @unique
  company                 Company                         @relation("SellerCompanyPayoutProfile", fields: [companyId], references: [id], onDelete: Restrict)
  bankDirectoryId         String?
  bankDirectory           BankDirectory?                  @relation(fields: [bankDirectoryId], references: [id], onDelete: SetNull)
  country                 String
  bankName                String
  branchName              String?
  accountHolder           String
  accountNumberCiphertext Bytes?
  accountNumberIv         Bytes?
  accountNumberAuthTag    Bytes?
  accountNumberKeyVersion String?
  accountNumberLast4      String?
  accountNumberMasked     String?
  accountType             PayoutAccountType               @default(LOCAL)
  bankCode                String?
  swiftBic                String?
  bankAddress             String?
  beneficiaryAddress      String?
  payoutCurrency          String                          @default("usd")
  supportedCurrencies     String[]                        @default([])
  intermediaryBankName    String?
  intermediaryBankSwift   String?
  intermediaryBankAddress String?
  payoutMemo              String?
  accountBelongsToCompany Boolean                         @default(false)
  manualBankOverride      Boolean                         @default(false)
  manualOverrideReason    String?
  status                  SellerPayoutProfileStatus       @default(DRAFT)
  verifiedAt              DateTime?
  verifiedByUserId        String?
  verifiedByUser          UserProfile?                    @relation("SellerPayoutProfileVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  auditEvents             SellerPayoutProfileAuditEvent[]
  payouts                 SellerPayout[]
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt

  @@index([status, updatedAt])
  @@index([bankDirectoryId])
}

model SellerPayoutProfileAuditEvent {
  id              String              @id @default(cuid())
  payoutProfileId String
  payoutProfile   SellerPayoutProfile @relation(fields: [payoutProfileId], references: [id], onDelete: Restrict)
  actorUserId     String
  actorUser       UserProfile         @relation("SellerPayoutProfileAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action          String
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now())

  @@index([payoutProfileId, createdAt])
  @@index([actorUserId, createdAt])
}

model PartnerPayoutProfile {
  id                      String                           @id @default(cuid())
  partnerProfileId        String                           @unique
  partnerProfile          PartnerProfile                   @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  bankDirectoryId         String
  bankDirectory           BankDirectory                    @relation(fields: [bankDirectoryId], references: [id], onDelete: Restrict)
  country                 String
  bankName                String
  accountHolder           String
  accountNumberCiphertext Bytes
  accountNumberIv         Bytes
  accountNumberAuthTag    Bytes
  accountNumberKeyVersion String
  accountNumberLast4      String
  accountNumberMasked     String
  accountType             PayoutAccountType                @default(LOCAL)
  payoutCurrency          String                           @default("krw")
  supportedCurrencies     String[]                         @default(["krw"])
