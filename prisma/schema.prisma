model PartnerPayoutProfileAuditEvent {
  id              String               @id @default(cuid())
  payoutProfileId String
  payoutProfile   PartnerPayoutProfile @relation(fields: [payoutProfileId], references: [id], onDelete: Restrict)
  actorUserId     String
  actorUser       UserProfile          @relation("PartnerPayoutProfileAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action          String
  metadata        Json                 @default("{}")
  createdAt       DateTime             @default(now())

  @@index([payoutProfileId, createdAt])
  @@index([actorUserId, createdAt])
}

model PartnerProfileAuditEvent {
  id               String         @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  actorUserId      String
  actorUser        UserProfile    @relation("PartnerProfileAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action           String
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())

  @@index([partnerProfileId, createdAt])
  @@index([actorUserId, createdAt])
