  orderId                         String
  order                           TradeOrder            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  partnerProfileId                String
  partnerProfile                  PartnerProfile        @relation(fields: [partnerProfileId], references: [id], onDelete: Restrict)
  payoutProfileId                 String?
  payoutProfile                   PartnerPayoutProfile? @relation(fields: [payoutProfileId], references: [id], onDelete: Restrict)
  payoutNumber                    String                @unique
  status                          PartnerPayoutStatus   @default(NOT_READY)
  currency                        String                @default("usd")
  originalCommissionAmount        Int
  reversalAdjustmentAmount        Int                   @default(0)
  finalPayoutAmount               Int
  holdUntil                       DateTime
  accountCountrySnapshot          String?
  accountTypeSnapshot             PayoutAccountType?
  payoutCurrencySnapshot          String?
  supportedCurrenciesSnapshot     String[]              @default([])
  bankNameSnapshot                String?
  accountHolderSnapshot           String?
  accountNumberSnapshotEncrypted  Bytes?
  accountNumberSnapshotIv         Bytes?
  accountNumberSnapshotAuthTag    Bytes?
  accountNumberSnapshotKeyVersion String?
  accountNumberLast4              String?
  accountNumberMasked             String?
  partnerLegalNameSnapshot        String?
  partnerDisplayNameSnapshot      String?
  partnerOrganizationSnapshot     String?
  partnerEmailSnapshot            String?
  partnerPhoneSnapshot            String?
  partnerResidenceCountrySnapshot String?
  preparedAt                      DateTime?
  preparedByUserId                String?
  preparedByUser                  UserProfile?          @relation("PartnerPayoutPreparedBy", fields: [preparedByUserId], references: [id], onDelete: SetNull)
  sentAt                          DateTime?
  sentByUserId                    String?
  sentByUser                      UserProfile?          @relation("PartnerPayoutSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  failedAt                        DateTime?
  externalTransferReference       String?
  externalBankReference           String?
  failureReason                   String?
  internalNote                    String?
  requiresManualReconciliation    Boolean               @default(false)
  events                          PartnerPayoutEvent[]
  createdAt                       DateTime              @default(now())
  updatedAt                       DateTime              @updatedAt

  @@index([partnerProfileId, createdAt])
  @@index([status, createdAt])
  @@index([payoutProfileId])
  @@index([orderId])
}

model PartnerPayoutEvent {
  id          String                 @id @default(cuid())
  payoutId    String
  payout      PartnerPayout          @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  actorUserId String?
  actorUser   UserProfile?           @relation("PartnerPayoutEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   PartnerPayoutEventType
  message     String?
  metadata    Json                   @default("{}")
  createdAt   DateTime               @default(now())

  @@index([payoutId, createdAt])
  @@index([eventType, createdAt])
}

model SavedItem {
  id          String        @id @default(cuid())
  userId      String
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  externalId  String?
  displayName String?
  imageUrl    String?
  href        String?
  type        SavedItemType
  createdAt   DateTime      @default(now())

  @@unique([userId, productId])
  @@unique([userId, companyId])
  @@unique([userId, type, externalId])
