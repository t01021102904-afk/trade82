generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountRole {
  user
  seller
  buyer
  both
  admin
}

enum PreferredLanguage {
  en
  ko
}

enum CompanyRole {
  seller
  buyer
}

enum CompanyVerificationStatus {
  unverified
  email_verified
  pending_review
  verified
  rejected
  needs_reverification
}

enum ProductStatus {
  active
  inactive
  draft
}

enum VerificationRequestStatus {
  pending_review
  verified
  rejected
}

enum InquiryStatus {
  sent
  replied
  closed
}

enum SavedItemType {
  product
  company
}

enum MessageAttachmentFileType {
  image
  pdf
  document
}

enum MessageAttachmentStatus {
  active
  hidden
  restricted
  flagged
}

enum DocumentCategory {
  company
  product
  compliance
  shipping
  contracts
  shared_with_buyer
}

enum DocumentVisibilityStatus {
  private
  internal_review
  shared_with_buyer
}

enum DealStatus {
  proposed
  in_progress
  completion_requested
  completed
  cancelled
  disputed
}

enum PublicValueDisplay {
  hidden
  exact
  range
}

enum RfqStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  MATCHING_READY
  CLOSED
  CANCELLED
}

enum RfqAdminStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RfqSellerQuoteStatus {
  REQUESTED
  SUBMITTED
  DECLINED
  NEGOTIATING
  ACCEPTED
  CLOSED
}

enum MarketingExposurePlan {
  LANDING_7D
  LANDING_30D
  LANDING_90D
}

enum MarketingExposureStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentRequestStatus {
  PENDING
  PAID
  RELEASED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED
}

enum PaymentRequestEventType {
  CREATED
  CHECKOUT_STARTED
  PAID
  RELEASED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTE_OPENED
  DISPUTE_UPDATED
  DISPUTE_CLOSED
  RECONCILIATION_REQUIRED
}

enum StripeFeeSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum TradeOrderStatus {
  PAYMENT_PENDING
  PAID
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum OrderPaymentStatus {
  UNPAID
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  DISPUTED
}

enum OrderShipmentStatus {
  NOT_READY
  READY
  BOOKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum OrderPayoutStatus {
  NOT_READY
  HOLD
  READY
  PROCESSING
  SENT
  FAILED
  RETURNED
  CANCELLED
}

enum Incoterm {
  EXW
  FCA
  FAS
  FOB
  CFR
  CIF
  CPT
  CIP
  DAP
  DPU
  DDP
  OTHER
}

enum ShippingMethod {
  OCEAN
  AIR
  EXPRESS
  POSTAL
  TRUCK
  COURIER
  OTHER
}

enum SellerPayoutProfileStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  DISABLED
}

enum PayoutAccountType {
  LOCAL
  FOREIGN_CURRENCY
  IBAN
  OTHER
}

enum SellerPayoutStatus {
  NOT_READY
  HOLD
  READY
  PROCESSING
  SENT
  FAILED
  RETURNED
  CANCELLED
}

enum WireFeeBearer {
  OUR
  SHA
  BEN
  NOT_APPLICABLE
}

enum TradeOrderEventType {
  ORDER_CREATED
  PAYMENT_REQUESTED
  CHECKOUT_STARTED
  PAYMENT_PAID
  PAYMENT_FAILED
  REFUND_CREATED
  REFUND_COMPLETED
  DISPUTE_OPENED
  DISPUTE_CLOSED
  PROCESSING_STARTED
  SHIPMENT_UPDATED
  SHIPPED
  DELIVERED
  PAYOUT_HOLD
  PAYOUT_READY
  PAYOUT_PROCESSING
  PAYOUT_SENT
  PAYOUT_FAILED
  ORDER_CANCELLED
  ORDER_COMPLETED
  ADMIN_NOTE
}

enum SellerPayoutEventType {
  CREATED
  ELIGIBILITY_CHECKED
  READY
  HOLD
  PROCESSING
  SENT
  FAILED
  RETURNED
  CANCELLED
  BANK_DETAILS_REVEALED
  INSTRUCTIONS_EXPORTED
  ADJUSTMENT_ADDED
}

enum SellerPayoutAdjustmentType {
  CREDIT
  DEBIT
  REFUND_RECOVERY
  BANK_FEE
  FX_ADJUSTMENT
  OTHER
}

// This enum is intentionally isolated from real order, payment, and payout
// states. Internal test runs are never linked to financial execution records.
enum InternalOrderTestStatus {
  CREATED
  SIMULATED_PAID
  SIMULATED_PARTIALLY_REFUNDED
  SIMULATED_REFUNDED
  CANCELLED
}

enum BankDirectorySourceType {
  SEED
  ADMIN
  ADMIN_OVERRIDE
}

model UserProfile {
  id                             String                          @id @default(cuid())
  clerkUserId                    String                          @unique
  email                          String                          @unique
  displayName                    String
  avatarOriginalUrl              String?
  avatarUrl                      String?
  companyAffiliation             String                          @default("")
  jobTitle                       String                          @default("")
  department                     String                          @default("")
  bio                            String                          @default("")
  phoneNumber                    String                          @default("")
  linkedinUrl                    String                          @default("")
  country                        String                          @default("")
  city                           String                          @default("")
  role                           AccountRole
  preferredLanguage              PreferredLanguage               @default(en)
  companies                      Company[]
  requestedVerifications         VerificationRequest[]           @relation("RequestedVerification")
  reviewedVerifications          VerificationRequest[]           @relation("ReviewedVerification")
  sentInquiries                  Inquiry[]                       @relation("InquirySender")
  sentMessages                   Message[]                       @relation("MessageSender")
  receivedMessages               Message[]                       @relation("MessageReceiver")
  uploadedMessageAttachments     MessageAttachment[]             @relation("MessageAttachmentUploader")
  createdDocumentFolders         DocumentFolder[]                @relation("CreatedDocumentFolders")
  uploadedTradeDocuments         TradeDocument[]                 @relation("UploadedTradeDocuments")
  savedItems                     SavedItem[]
  createdDeals                   Deal[]                          @relation("DealCreator")
  buyerRfqRequests               RfqRequest[]                    @relation("BuyerRfqRequests")
  reviewedRfqRequests            RfqRequest[]                    @relation("ReviewedRfqRequests")
  marketingExposures             MarketingExposure[]
  createdPaymentRequests         PaymentRequest[]                @relation("PaymentRequestCreator")
  releasedPaymentRequests        PaymentRequest[]                @relation("PaymentRequestReleasedBy")
  paymentRequestEvents           PaymentRequestEvent[]           @relation("PaymentRequestEventActor")
  tradeOrderEvents               TradeOrderEvent[]               @relation("TradeOrderEventActor")
  sellerPayoutEvents             SellerPayoutEvent[]             @relation("SellerPayoutEventActor")
  sellerPayoutAdjustments        SellerPayoutAdjustment[]        @relation("SellerPayoutAdjustmentActor")
  preparedSellerPayouts          SellerPayout[]                  @relation("SellerPayoutPreparedBy")
  approvedSellerPayouts          SellerPayout[]                  @relation("SellerPayoutApprovedBy")
  sentSellerPayouts              SellerPayout[]                  @relation("SellerPayoutSentBy")
  verifiedSellerPayoutProfiles   SellerPayoutProfile[]           @relation("SellerPayoutProfileVerifiedBy")
  sellerPayoutProfileAuditEvents SellerPayoutProfileAuditEvent[] @relation("SellerPayoutProfileAuditActor")
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
}

model Company {
  id                                String                    @id @default(cuid())
  ownerUserId                       String
  owner                             UserProfile               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  companyRole                       CompanyRole
  legalName                         String
  tradeName                         String?
  displayNameEn                     String                    @default("")
  logoOriginalUrl                   String?
  logoThumbnailUrl                  String?
  logoUrl                           String?
  useDefaultLogo                    Boolean                   @default(true)
  website                           String                    @default("")
  country                           String
  city                              String                    @default("")
  stateOrProvince                   String                    @default("")
  businessAddress                   String
  description                       String                    @default("")
  descriptionEn                     String                    @default("")
  categories                        String[]                  @default([])
  viewCount                         Int                       @default(0)
  verificationStatus                CompanyVerificationStatus @default(unverified)
  stripeCustomerId                  String?                   @unique
  stripeSubscriptionId              String?                   @unique
  subscriptionStatus                String?
  subscriptionPlan                  String?
  subscriptionCurrentPeriodEnd      DateTime?
  verifiedSellerSince               DateTime?
  sellerSupportPlan                 String?
  sellerSupportStatus               String?
  sellerSupportStripeCustomerId     String?                   @unique
  sellerSupportStripeSubscriptionId String?                   @unique
  sellerSupportCurrentPeriodEnd     DateTime?
  sellerSupportMonthlyLimit         Int                       @default(0)
  sellerSupportMonthlyUsed          Int                       @default(0)
  sellerProfile                     SellerProfile?
  buyerProfile                      BuyerProfile?
  products                          Product[]
  verificationRequests              VerificationRequest[]
  buyerInquiries                    Inquiry[]                 @relation("BuyerCompanyInquiries")
  sellerInquiries                   Inquiry[]                 @relation("SellerCompanyInquiries")
  recipientInquiries                Inquiry[]                 @relation("RecipientCompanyInquiries")
  rfqSellerQuotes                   RfqSellerQuote[]          @relation("SellerCompanyRfqQuotes")
  sentCompanyMessages               Message[]                 @relation("MessageSenderCompany")
  receivedMessages                  Message[]                 @relation("MessageReceiverCompany")
  uploadedMessageAttachments        MessageAttachment[]       @relation("MessageAttachmentCompany")
  documentFolders                   DocumentFolder[]          @relation("CompanyDocumentFolders")
  tradeDocuments                    TradeDocument[]           @relation("CompanyTradeDocuments")
  sharedTradeDocuments              TradeDocument[]           @relation("SharedBuyerDocuments")
  savedItems                        SavedItem[]
  buyerDeals                        Deal[]                    @relation("BuyerCompanyDeals")
  sellerDeals                       Deal[]                    @relation("SellerCompanyDeals")
  buyerRfqRequests                  RfqRequest[]              @relation("BuyerCompanyRfqs")
  marketingExposures                MarketingExposure[]
  buyerPaymentRequests              PaymentRequest[]          @relation("BuyerCompanyPaymentRequests")
  sellerPaymentRequests             PaymentRequest[]          @relation("SellerCompanyPaymentRequests")
  buyerTradeOrders                  TradeOrder[]              @relation("BuyerCompanyTradeOrders")
  sellerTradeOrders                 TradeOrder[]              @relation("SellerCompanyTradeOrders")
  sellerPayoutProfile               SellerPayoutProfile?      @relation("SellerCompanyPayoutProfile")
  sellerPayouts                     SellerPayout[]            @relation("SellerCompanyPayouts")
  reviewsWritten                    Review[]                  @relation("ReviewWriter")
  reviewsReceived                   Review[]                  @relation("ReviewRecipient")
  companyReviewsWritten             CompanyReview[]           @relation("CompanyReviewWriter")
  companyReviewsReceived            CompanyReview[]           @relation("CompanyReviewRecipient")
  createdAt                         DateTime                  @default(now())
  updatedAt                         DateTime                  @updatedAt

  @@unique([ownerUserId, companyRole])
  @@index([companyRole, verificationStatus])
  @@index([subscriptionStatus, subscriptionPlan])
  @@index([sellerSupportStatus, sellerSupportPlan])
}

model SellerProfile {
  id                               String   @id @default(cuid())
  companyId                        String   @unique
  company                          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  koreanBusinessRegistrationNumber String
  representativeName               String
  exportExperience                 String
  exportExperienceEn               String   @default("")
  exportCountries                  String[] @default([])
  productCategories                String[] @default([])
  minimumOrderQuantity             String
  leadTime                         String
  certifications                   String[] @default([])
  shippingTerms                    String[] @default([])
  paymentTerms                     String[] @default([])
  factoryOrDistributorStatus       String
}

model BuyerProfile {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buyerType             String
  purchasingCategories  String[] @default([])
  preferredSupplierType String   @default("")
  targetOrderSize       String
  monthlyImportVolume   String
  importExperience      String
  purchaseTimeline      String
  salesChannels         String[] @default([])
}

model Product {
  id                       String              @id @default(cuid())
  sellerCompanyId          String
  sellerCompany            Company             @relation(fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  name                     String
  nameEn                   String              @default("")
  slug                     String              @unique
  imageUrl                 String?
  category                 String
  tags                     String[]            @default([])
  tagsEn                   String[]            @default([])
  shortDescription         String
  shortDescriptionEn       String              @default("")
  detailedDescription      String
  detailedDescriptionEn    String              @default("")
  priceMin                 Decimal?            @db.Decimal(14, 2)
  priceMax                 Decimal?            @db.Decimal(14, 2)
  currency                 String              @default("USD")
  priceUnit                String              @default("unit")
  moq                      String
  moqQuantity              String              @default("")
  moqUnit                  String              @default("Units")
  leadTime                 String
  leadTimeCode             String              @default("")
  sampleAvailability       String              @default("")
  privateLabelAvailability String              @default("")
  monthlyCapacity          String              @default("")
  monthlyCapacityUnit      String              @default("Units")
  origin                   String              @default("South Korea")
  countryOfOrigin          String              @default("South Korea")
  shippingOriginCountry    String              @default("South Korea")
  shippingOriginRegion     String              @default("")
  incoterms                String[]            @default([])
  hsCode                   String              @default("")
  shelfLife                String              @default("")
  storageRequirements      String              @default("")
  documentsAvailable       String[]            @default([])
  complianceClaims         String[]            @default([])
  buyerNotes               String              @default("")
  buyerNotesEn             String              @default("")
  riskNotes                String[]            @default([])
  certifications           String[]            @default([])
  ingredientsOrMaterials   String
  packaging                String
  packageSize              String              @default("")
  unitsPerCarton           String              @default("")
  cartonWeight             String              @default("")
  cartonDimensions         String              @default("")
  palletQuantity           String              @default("")
  storageTemperature       String              @default("")
  suggestedUsChannels      String[]            @default([])
  fieldVisibility          Json                @default("{}") @map("field_visibility")
  exportReadiness          Boolean             @default(false)
  viewCount                Int                 @default(0)
  status                   ProductStatus       @default(draft)
  images                   ProductImage[]
  inquiries                Inquiry[]
  savedItems               SavedItem[]
  deals                    Deal[]
  rfqMatches               RfqMatchedProduct[]
  rfqSellerQuotes          RfqSellerQuote[]
  marketingExposures       MarketingExposure[]
  orderItems               TradeOrderItem[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([sellerCompanyId, status])
  @@index([category])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalUrl String
  cardUrl     String
  mainUrl     String
  detailUrl   String
  storagePath String
  position    Int
  width       Int?
  height      Int?
  altText     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, position])
  @@index([productId, position])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationRequest {
  id                String                    @id @default(cuid())
  companyId         String
  company           Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedByUserId String
  requestedBy       UserProfile               @relation("RequestedVerification", fields: [requestedByUserId], references: [id])
  status            VerificationRequestStatus @default(pending_review)
  documentUrl       String?
  documentPath      String?
  documentFilename  String?
  adminNote         String?
  reviewedByUserId  String?
  reviewedBy        UserProfile?              @relation("ReviewedVerification", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([status, createdAt])
}

model Inquiry {
  id                 String              @id @default(cuid())
  buyerCompanyId     String
  buyerCompany       Company             @relation("BuyerCompanyInquiries", fields: [buyerCompanyId], references: [id])
  sellerCompanyId    String
  sellerCompany      Company             @relation("SellerCompanyInquiries", fields: [sellerCompanyId], references: [id])
  productId          String?
  product            Product?            @relation(fields: [productId], references: [id])
  senderUserId       String
  sender             UserProfile         @relation("InquirySender", fields: [senderUserId], references: [id])
  recipientCompanyId String
  recipientCompany   Company             @relation("RecipientCompanyInquiries", fields: [recipientCompanyId], references: [id])
  message            String
  quantity           String?
  targetDate         DateTime?
  status             InquiryStatus       @default(sent)
  messages           Message[]
  attachments        MessageAttachment[]
  deals              Deal[]
  paymentRequests    PaymentRequest[]
  tradeOrders        TradeOrder[]
  rfqSellerQuotes    RfqSellerQuote[]    @relation("RfqQuoteConversation")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([buyerCompanyId, sellerCompanyId])
  @@index([recipientCompanyId, status])
}

model RfqRequest {
  id                         String              @id @default(cuid())
  buyerUserId                String
  buyerUser                  UserProfile         @relation("BuyerRfqRequests", fields: [buyerUserId], references: [id], onDelete: Cascade)
  buyerCompanyId             String?
  buyerCompany               Company?            @relation("BuyerCompanyRfqs", fields: [buyerCompanyId], references: [id], onDelete: SetNull)
  productName                String
  category                   String
  sourcingType               String
  sourcingPurpose            String?
  quantity                   String
  tradeTerms                 String
  destinationCountry         String?
  preferredUnitPriceAmount   Decimal?            @db.Decimal(14, 2)
  preferredUnitPriceCurrency String?
  shape                      String?
  capacity                   String?
  material                   String?
  certification              String?
  feature                    String?
  targetDeliveryDate         DateTime?
  details                    String
  status                     RfqStatus           @default(SUBMITTED)
  adminStatus                RfqAdminStatus      @default(PENDING_REVIEW)
  adminNote                  String?
  reviewedByUserId           String?
  reviewedByUser             UserProfile?        @relation("ReviewedRfqRequests", fields: [reviewedByUserId], references: [id])
  reviewedAt                 DateTime?
  matchedProducts            RfqMatchedProduct[]
  sellerQuotes               RfqSellerQuote[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  @@index([buyerUserId, createdAt])
  @@index([buyerCompanyId, createdAt])
  @@index([status, createdAt])
  @@index([adminStatus, createdAt])
}

model RfqMatchedProduct {
  id           String     @id @default(cuid())
  rfqRequestId String
  rfqRequest   RfqRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  rank         Int
  reasons      String[]   @default([])
  createdAt    DateTime   @default(now())

  @@unique([rfqRequestId, productId])
  @@index([rfqRequestId, rank])
  @@index([productId])
}

model RfqSellerQuote {
  id                    String               @id @default(cuid())
  rfqRequestId          String
  rfqRequest            RfqRequest           @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  sellerCompanyId       String
  sellerCompany         Company              @relation("SellerCompanyRfqQuotes", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  productId             String?
  product               Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  conversationId        String?
  conversation          Inquiry?             @relation("RfqQuoteConversation", fields: [conversationId], references: [id], onDelete: SetNull)
  status                RfqSellerQuoteStatus @default(REQUESTED)
  unitPriceAmount       Decimal?             @db.Decimal(14, 2)
  unitPriceCurrency     String?
  moq                   String?
  leadTime              String?
  incoterms             String?
  sampleAvailable       Boolean?
  privateLabelAvailable Boolean?
  notes                 String?
  submittedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([rfqRequestId, sellerCompanyId])
  @@index([rfqRequestId, status])
  @@index([sellerCompanyId, createdAt])
  @@index([productId])
  @@index([conversationId])
}

model MarketingExposure {
  id                      String                  @id @default(cuid())
  companyId               String
  company                 Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId               String
  product                 Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId                  String
  user                    UserProfile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                    MarketingExposurePlan
  status                  MarketingExposureStatus @default(PENDING)
  stripeCustomerId        String?
  stripeCheckoutSessionId String?                 @unique
  stripePaymentIntentId   String?
  priceId                 String
  amount                  Int
  currency                String                  @default("usd")
  startsAt                DateTime?
  endsAt                  DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([companyId, status])
  @@index([productId, status])
  @@index([status, startsAt, endsAt])
}

model PaymentRequest {
  id                           String                       @id @default(cuid())
  inquiryId                    String
  inquiry                      Inquiry                      @relation(fields: [inquiryId], references: [id], onDelete: Restrict)
  buyerCompanyId               String
  buyerCompany                 Company                      @relation("BuyerCompanyPaymentRequests", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompanyId              String
  sellerCompany                Company                      @relation("SellerCompanyPaymentRequests", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  createdByUserId              String
  createdByUser                UserProfile                  @relation("PaymentRequestCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  productName                  String
  quantity                     String
  unit                         String
  productAmount                Int
  shippingAmount               Int
  grossAmount                  Int
  platformFeeAmount            Int
  sellerPayableAmount          Int
  stripeProcessingFeeAmount    Int?
  stripeFeeSyncStatus          StripeFeeSyncStatus          @default(PENDING)
  stripeFeeSyncError           String?
  stripeFeeSyncedAt            DateTime?
  refundAmount                 Int                          @default(0)
  currency                     String                       @default("usd")
  paymentDueDate               DateTime
  orderTerms                   String
  status                       PaymentRequestStatus         @default(PENDING)
  stripeCheckoutSessionId      String?                      @unique
  stripePaymentIntentId        String?                      @unique
  stripeChargeId               String?                      @unique
  checkoutAttempt              Int                          @default(0)
  checkoutLockToken            String?
  checkoutLockExpiresAt        DateTime?
  paidAt                       DateTime?
  cancelledAt                  DateTime?
  releasedAt                   DateTime?
  manualPayoutReference        String?
  manualPayoutDate             DateTime?
  manualPayoutNote             String?
  sellerReleasedAmount         Int?
  releasedByUserId             String?
  releasedByUser               UserProfile?                 @relation("PaymentRequestReleasedBy", fields: [releasedByUserId], references: [id], onDelete: SetNull)
  requiresManualReconciliation Boolean                      @default(false)
  reconciliationNote           String?
  orderId                      String?                      @unique
  order                        TradeOrder?                  @relation("PaymentRequestOrder", fields: [orderId], references: [id], onDelete: Restrict)
  tradeOrderByPaymentRequest   TradeOrder?                  @relation("TradeOrderPaymentRequest")
  refunds                      PaymentRefund[]
  disputes                     PaymentDispute[]
  events                       PaymentRequestEvent[]
  webhookEvents                PaymentRequestWebhookEvent[]
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  @@index([inquiryId, createdAt])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
  @@index([status, paymentDueDate])
  @@index([status, checkoutLockExpiresAt])
}

model PaymentRefund {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeRefundId   String         @unique
  amount           Int
  status           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([paymentRequestId, createdAt])
}

model PaymentDispute {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeDisputeId  String         @unique
  amount           Int
  status           String
  reason           String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([paymentRequestId, createdAt])
}

model PaymentRequestEvent {
  id               String                  @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest          @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  eventType        PaymentRequestEventType
  actorUserId      String?
  actorUser        UserProfile?            @relation("PaymentRequestEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  stripeEventId    String?                 @unique
  message          String?
  metadata         Json                    @default("{}")
  createdAt        DateTime                @default(now())

  @@index([paymentRequestId, createdAt])
  @@index([eventType, createdAt])
}

model PaymentRequestWebhookEvent {
  id               String         @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  stripeEventId    String         @unique
  stripeEventType  String
  createdAt        DateTime       @default(now())

  @@index([paymentRequestId, createdAt])
}

// Financial order records deliberately use restrictive foreign keys. Historical
// payments and payout instructions must remain auditable even when other app data
// is otherwise eligible for deletion.
model OrderNumberCounter {
  year               Int      @id
  lastOrderSequence  Int      @default(0)
  lastPayoutSequence Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TradeOrder {
  id                      String              @id @default(cuid())
  orderNumber             String              @unique
  inquiryId               String
  inquiry                 Inquiry             @relation(fields: [inquiryId], references: [id], onDelete: Restrict)
  paymentRequestId        String              @unique
  paymentRequest          PaymentRequest      @relation("TradeOrderPaymentRequest", fields: [paymentRequestId], references: [id], onDelete: Restrict)
  paymentRequestByOrderId PaymentRequest?     @relation("PaymentRequestOrder")
  buyerCompanyId          String
  buyerCompany            Company             @relation("BuyerCompanyTradeOrders", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompanyId         String
  sellerCompany           Company             @relation("SellerCompanyTradeOrders", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  orderStatus             TradeOrderStatus    @default(PAYMENT_PENDING)
  paymentStatus           OrderPaymentStatus  @default(PENDING)
  shipmentStatus          OrderShipmentStatus @default(NOT_READY)
  payoutStatus            OrderPayoutStatus   @default(NOT_READY)

  buyerCompanyName  String
  buyerContactName  String?
  buyerEmail        String
  buyerPhone        String?
  buyerCountry      String
  buyerAddress      String?
  sellerCompanyName String
  sellerContactName String?
  sellerEmail       String
  sellerPhone       String?
  sellerCountry     String
  sellerAddress     String?

  productAmount             Int
  shippingAmount            Int
  grossAmount               Int
  platformFeeRateBps        Int       @default(500)
  platformFeeAmount         Int
  sellerPayableAmount       Int
  stripeProcessingFeeAmount Int?
  refundAmount              Int       @default(0)
  currency                  String    @default("usd")
  paidAt                    DateTime?
  refundedAt                DateTime?
  disputedAt                DateTime?

  items     TradeOrderItem[]
  shipment  TradeOrderShipment?
  events    TradeOrderEvent[]
  payout    SellerPayout?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([buyerCompanyId, createdAt])
  @@index([sellerCompanyId, createdAt])
  @@index([orderStatus, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([payoutStatus, createdAt])
}

model TradeOrderItem {
  id              String     @id @default(cuid())
  orderId         String
  order           TradeOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  productId       String?
  product         Product?   @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  sku             String?
  hsCode          String?
  countryOfOrigin String?
  quantity        String
  unit            String
  unitPrice       Int?
  productAmount   Int
  currency        String     @default("usd")
  productSnapshot Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([orderId, createdAt])
  @@index([productId])
}

model TradeOrderShipment {
  id                   String              @id @default(cuid())
  orderId              String              @unique
  order                TradeOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  incoterm             Incoterm            @default(OTHER)
  shippingMethod       ShippingMethod      @default(OTHER)
  originCountry        String
  originCity           String?
  destinationCountry   String
  destinationCity      String?
  destinationAddress   String?
  carrierName          String?
  freightForwarderName String?
  trackingNumber       String?
  billOfLadingNumber   String?
  airWaybillNumber     String?
  shipmentReference    String?
  shipDate             DateTime?
  estimatedArrivalDate DateTime?
  deliveredAt          DateTime?
  shipmentStatus       OrderShipmentStatus @default(NOT_READY)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([shipmentStatus, updatedAt])
  @@index([destinationCountry])
}

model TradeOrderEvent {
  id          String              @id @default(cuid())
  orderId     String
  order       TradeOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  actorUserId String?
  actorUser   UserProfile?        @relation("TradeOrderEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   TradeOrderEventType
  message     String?
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now())

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model BankDirectory {
  id                 String                  @id @default(cuid())
  countryCode        String
  bankNameLocal      String
  bankNameEnglish    String
  bankCode           String?
  defaultSwiftBic    String?
  defaultBankAddress String?
  officialWebsite    String?
  sourceUrl          String?
  verifiedAt         DateTime?
  sourceType         BankDirectorySourceType @default(ADMIN)
  isActive           Boolean                 @default(true)
  payoutProfiles     SellerPayoutProfile[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([countryCode, bankNameEnglish])
  @@index([countryCode, isActive])
}

model SellerPayoutProfile {
  id                      String                          @id @default(cuid())
  companyId               String                          @unique
  company                 Company                         @relation("SellerCompanyPayoutProfile", fields: [companyId], references: [id], onDelete: Restrict)
  bankDirectoryId         String?
  bankDirectory           BankDirectory?                  @relation(fields: [bankDirectoryId], references: [id], onDelete: SetNull)
  country                 String
  bankName                String
  branchName              String?
  accountHolder           String
  accountNumberCiphertext Bytes?
  accountNumberIv         Bytes?
  accountNumberAuthTag    Bytes?
  accountNumberKeyVersion String?
  accountNumberLast4      String?
  accountNumberMasked     String?
  accountType             PayoutAccountType               @default(LOCAL)
  bankCode                String?
  swiftBic                String?
  bankAddress             String?
  beneficiaryAddress      String?
  payoutCurrency          String                          @default("usd")
  supportedCurrencies     String[]                        @default([])
  intermediaryBankName    String?
  intermediaryBankSwift   String?
  intermediaryBankAddress String?
  payoutMemo              String?
  accountBelongsToCompany Boolean                         @default(false)
  manualBankOverride      Boolean                         @default(false)
  manualOverrideReason    String?
  status                  SellerPayoutProfileStatus       @default(DRAFT)
  verifiedAt              DateTime?
  verifiedByUserId        String?
  verifiedByUser          UserProfile?                    @relation("SellerPayoutProfileVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  auditEvents             SellerPayoutProfileAuditEvent[]
  payouts                 SellerPayout[]
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt

  @@index([status, updatedAt])
  @@index([bankDirectoryId])
}

model SellerPayoutProfileAuditEvent {
  id              String              @id @default(cuid())
  payoutProfileId String
  payoutProfile   SellerPayoutProfile @relation(fields: [payoutProfileId], references: [id], onDelete: Restrict)
  actorUserId     String
  actorUser       UserProfile         @relation("SellerPayoutProfileAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action          String
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now())

  @@index([payoutProfileId, createdAt])
  @@index([actorUserId, createdAt])
}

model SellerPayout {
  id                            String                   @id @default(cuid())
  orderId                       String                   @unique
  order                         TradeOrder               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  sellerCompanyId               String
  sellerCompany                 Company                  @relation("SellerCompanyPayouts", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  payoutProfileId               String
  payoutProfile                 SellerPayoutProfile      @relation(fields: [payoutProfileId], references: [id], onDelete: Restrict)
  payoutNumber                  String                   @unique
  status                        SellerPayoutStatus       @default(READY)
  currency                      String                   @default("usd")
  grossAmount                   Int
  platformFeeRateBps            Int                      @default(500)
  platformFeeAmount             Int
  sellerPayableAmount           Int
  refundAdjustmentAmount        Int                      @default(0)
  manualAdjustmentAmount        Int                      @default(0)
  finalPayoutAmount             Int
  processingFeeAmount           Int?
  exchangeRate                  Decimal?                 @db.Decimal(20, 8)
  settlementCurrency            String?
  settlementAmount              Int?
  wireFeeBearer                 WireFeeBearer            @default(NOT_APPLICABLE)
  beneficiarySnapshotEncrypted  Bytes
  beneficiarySnapshotIv         Bytes
  beneficiarySnapshotAuthTag    Bytes
  beneficiarySnapshotKeyVersion String
  accountNumberLast4            String?
  bankNameSnapshot              String
  swiftBicSnapshot              String?
  officialBankWebsiteSnapshot   String?
  preparedAt                    DateTime?
  preparedByUserId              String?
  preparedByUser                UserProfile?             @relation("SellerPayoutPreparedBy", fields: [preparedByUserId], references: [id], onDelete: SetNull)
  approvedAt                    DateTime?
  approvedByUserId              String?
  approvedByUser                UserProfile?             @relation("SellerPayoutApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  sentAt                        DateTime?
  sentByUserId                  String?
  sentByUser                    UserProfile?             @relation("SellerPayoutSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  failedAt                      DateTime?
  externalTransferReference     String?
  externalBankReference         String?
  payoutProofStoragePath        String?
  failureReason                 String?
  internalNote                  String?
  events                        SellerPayoutEvent[]
  adjustments                   SellerPayoutAdjustment[]
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt

  @@index([sellerCompanyId, createdAt])
  @@index([status, createdAt])
  @@index([payoutProfileId])
}

model SellerPayoutEvent {
  id          String                @id @default(cuid())
  payoutId    String
  payout      SellerPayout          @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  actorUserId String?
  actorUser   UserProfile?          @relation("SellerPayoutEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   SellerPayoutEventType
  message     String?
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now())

  @@index([payoutId, createdAt])
  @@index([eventType, createdAt])
}

// Adjustments are append-only accounting entries. For unsent payouts, the
// materialized totals are recalculated from this ledger in one transaction.
// Sent payouts keep their recorded financial amounts immutable and instead
// receive a reconciliation-required adjustment record.
model SellerPayoutAdjustment {
  id                           String                     @id @default(cuid())
  payoutId                     String
  payout                       SellerPayout               @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  adjustmentType               SellerPayoutAdjustmentType
  amount                       Int
  currency                     String                     @default("usd")
  reason                       String
  internalNote                 String?
  requiresManualReconciliation Boolean                    @default(false)
  createdByUserId              String
  createdByUser                UserProfile                @relation("SellerPayoutAdjustmentActor", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt                    DateTime                   @default(now())

  @@index([payoutId, createdAt])
  @@index([createdByUserId, createdAt])
}

// Internal production tests are stored separately from TradeOrder,
// PaymentRequest, and SellerPayout. This keeps simulations permanently
// identifiable and structurally unable to enter real financial workflows.
model InternalOrderTestRun {
  id                       String                  @id @default(cuid())
  isInternalTest           Boolean                 @default(true)
  testLabel                String                  @default("INTERNAL_PRODUCTION_TEST")
  testerClerkUserId        String
  idempotencyKey           String                  @unique
  testOrderReference       String                  @unique
  status                   InternalOrderTestStatus @default(CREATED)
  productName              String
  productAmount            Int
  shippingAmount           Int
  grossAmount              Int
  platformFeeAmount        Int
  sellerPayableAmount      Int
  currency                 String                  @default("usd")
  simulatedPaidAmount      Int                     @default(0)
  simulatedRefundAmount    Int                     @default(0)
  payoutPreviewAmount      Int?
  payoutPreviewGeneratedAt DateTime?
  version                  Int                     @default(0)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([testerClerkUserId, createdAt])
  @@index([isInternalTest, createdAt])
}

model SavedItem {
  id          String        @id @default(cuid())
  userId      String
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  externalId  String?
  displayName String?
  imageUrl    String?
  href        String?
  type        SavedItemType
  createdAt   DateTime      @default(now())

  @@unique([userId, productId])
  @@unique([userId, companyId])
  @@unique([userId, type, externalId])
}

model Message {
  id                String              @id @default(cuid())
  inquiryId         String?
  inquiry           Inquiry?            @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  senderUserId      String
  sender            UserProfile         @relation("MessageSender", fields: [senderUserId], references: [id])
  receiverUserId    String?
  receiver          UserProfile?        @relation("MessageReceiver", fields: [receiverUserId], references: [id])
  senderCompanyId   String?
  senderCompany     Company?            @relation("MessageSenderCompany", fields: [senderCompanyId], references: [id])
  receiverCompanyId String?
  receiverCompany   Company?            @relation("MessageReceiverCompany", fields: [receiverCompanyId], references: [id])
  body              String
  contentHash       String              @default("")
  attachments       MessageAttachment[]
  createdAt         DateTime            @default(now())

  @@index([inquiryId, createdAt])
}

model MessageAttachment {
  id                  String                    @id @default(cuid())
  messageId           String?
  message             Message?                  @relation(fields: [messageId], references: [id], onDelete: SetNull)
  inquiryId           String
  inquiry             Inquiry                   @relation(fields: [inquiryId], references: [id])
  uploadedByUserId    String
  uploadedByUser      UserProfile               @relation("MessageAttachmentUploader", fields: [uploadedByUserId], references: [id])
  uploadedByCompanyId String
  uploadedByCompany   Company                   @relation("MessageAttachmentCompany", fields: [uploadedByCompanyId], references: [id])
  originalFilename    String
  storedFilename      String
  storageBucket       String
  storagePath         String                    @unique
  mimeType            String
  fileType            MessageAttachmentFileType
  sizeBytes           Int
  sha256Hash          String
  status              MessageAttachmentStatus   @default(restricted)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([inquiryId, createdAt])
  @@index([messageId])
  @@index([uploadedByUserId, createdAt])
  @@index([status, createdAt])
}

model DocumentFolder {
  id              String           @id @default(cuid())
  companyId       String           @map("company_id")
  company         Company          @relation("CompanyDocumentFolders", fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId String           @map("created_by_user_id")
  createdByUser   UserProfile      @relation("CreatedDocumentFolders", fields: [createdByUserId], references: [id], onDelete: Cascade)
  name            String
  category        DocumentCategory
  documents       TradeDocument[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([companyId, category, name])
  @@index([companyId, category])
  @@map("document_folders")
}

model TradeDocument {
  id               String                   @id @default(cuid())
  companyId        String                   @map("company_id")
  company          Company                  @relation("CompanyTradeDocuments", fields: [companyId], references: [id], onDelete: Cascade)
  uploadedByUserId String                   @map("uploaded_by_user_id")
  uploadedByUser   UserProfile              @relation("UploadedTradeDocuments", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  fileName         String                   @map("file_name")
  fileUrl          String                   @map("file_url")
  fileType         String                   @map("file_type")
  fileSize         Int                      @map("file_size")
  storageBucket    String                   @map("storage_bucket")
  storagePath      String                   @unique @map("storage_path")
  mimeType         String                   @map("mime_type")
  category         DocumentCategory
  folderId         String?                  @map("folder_id")
  folder           DocumentFolder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  visibilityStatus DocumentVisibilityStatus @default(private) @map("visibility_status")
  sharedBuyerId    String?                  @map("shared_buyer_id")
  sharedBuyer      Company?                 @relation("SharedBuyerDocuments", fields: [sharedBuyerId], references: [id], onDelete: SetNull)
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  @@index([companyId, category, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([folderId])
  @@index([sharedBuyerId])
  @@map("trade_documents")
}

model Deal {
  id                 String             @id @default(cuid())
  inquiryId          String?
  inquiry            Inquiry?           @relation(fields: [inquiryId], references: [id])
  buyerCompanyId     String
  buyerCompany       Company            @relation("BuyerCompanyDeals", fields: [buyerCompanyId], references: [id])
  sellerCompanyId    String
  sellerCompany      Company            @relation("SellerCompanyDeals", fields: [sellerCompanyId], references: [id])
  productId          String?
  product            Product?           @relation(fields: [productId], references: [id])
  contractTitle      String
  contractValue      Decimal            @db.Decimal(16, 2)
  currency           String             @default("USD")
  dealStatus         DealStatus         @default(proposed)
  completedAt        DateTime?
  createdByUserId    String
  createdBy          UserProfile        @relation("DealCreator", fields: [createdByUserId], references: [id])
  confirmedByBuyer   Boolean            @default(false)
  confirmedBySeller  Boolean            @default(false)
  isPublic           Boolean            @default(false)
  publicValueDisplay PublicValueDisplay @default(hidden)
  contractFilePath   String?
  contractFileName   String?
  reviews            Review[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([buyerCompanyId, sellerCompanyId, dealStatus])
}

model Review {
  id                   String             @id @default(cuid())
  dealId               String
  deal                 Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reviewerCompanyId    String
  reviewerCompany      Company            @relation("ReviewWriter", fields: [reviewerCompanyId], references: [id])
  reviewedCompanyId    String
  reviewedCompany      Company            @relation("ReviewRecipient", fields: [reviewedCompanyId], references: [id])
  rating               Int
  reviewTitle          String?
  reviewText           String
  contractValue        Decimal            @db.Decimal(16, 2)
  currency             String             @default("USD")
  isVerifiedDealReview Boolean            @default(true)
  publicValueDisplay   PublicValueDisplay @default(hidden)
  isPublic             Boolean            @default(true)
  adminApproved        Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([dealId, reviewerCompanyId])
  @@index([reviewedCompanyId, isPublic, adminApproved])
}

model CompanyReview {
  id                String    @id @default(cuid())
  reviewerCompanyId String
  reviewerCompany   Company   @relation("CompanyReviewWriter", fields: [reviewerCompanyId], references: [id], onDelete: Cascade)
  reviewedCompanyId String
  reviewedCompany   Company   @relation("CompanyReviewRecipient", fields: [reviewedCompanyId], references: [id], onDelete: Cascade)
  rating            Int
  comment           String
  isPublic          Boolean   @default(true)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([reviewedCompanyId, isPublic, createdAt])
  @@index([reviewerCompanyId, createdAt])
}
