{
  "name": "bridgemarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-production-migrations.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:payments && npm run test:orders && npm run test:production-migrations && npm run test:partner-referral-analytics && npm run test:admin-partners && npm run test:localization && NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test tests/stripe-connect-settlement.test.ts tests/stripe-connect-transfer-reversal.test.ts tests/settlement-operations-control-plane.test.ts",
    "test:payments": "node --experimental-strip-types --test tests/payment-request-rules.test.ts tests/payment-request-safety.test.ts",
    "test:orders": "NODE_OPTIONS=--conditions=react-server node --experimental-strip-types --test tests/order-manual-payout.test.ts",
    "test:orders:integration": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test --test-concurrency=1 tests/order-manual-payout.integration.test.ts",
    "test:production-migrations": "node --test tests/run-production-migrations.test.mjs",
    "test:admin-partners": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test tests/admin-partners.test.ts",
    "test:localization": "node --experimental-strip-types --test tests/sitewide-localization-and-buttons.test.ts",
    "test:admin-partners:integration": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test --test-concurrency=1 tests/admin-partners.integration.test.ts",
    "test:partner-referral-analytics": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test tests/partner-referral-analytics.test.ts",
    "test:partner-routing:e2e": "node --test tests/partner-routing.e2e.test.mjs",
    "test:partner-referral-analytics:integration": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --experimental-test-module-mocks --test --test-concurrency=1 tests/partner-referral-route.integration.test.ts tests/partner-referral-retention.integration.test.ts tests/partner-program.integration.test.ts tests/account-deletion.integration.test.ts tests/partner-referral-analytics-timezone.integration.test.ts",
    "test:settlement-operations:catalog": "node --test tests/settlement-operations.integration.test.mjs",
    "test:settlement-operations:workers": "NODE_OPTIONS='--conditions=react-server --import=./tests/register-test-alias.mjs' node --experimental-strip-types --test --test-concurrency=1 tests/settlement-operations.worker.integration.test.ts",
    "production:payments:check": "node scripts/check-payment-production-env.mjs",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed:south-korean-banks": "node --experimental-strip-types scripts/seed-south-korea-bank-directory.ts",
    "backfill:english": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/backfill-english-content.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
